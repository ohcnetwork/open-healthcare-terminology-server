# Copy this file to .env for local Docker Compose usage.
# Do not put real production secrets in this example file.

POSTGRES_DB=ots
POSTGRES_USER=ots
POSTGRES_PASSWORD=ots

OTS_DATABASE_URL=postgresql://ots:ots@postgres:5432/ots
OTS_SQLALCHEMY_DATABASE_URL=postgresql+psycopg://ots:ots@postgres:5432/ots

OTS_API_KEY=open-terminology-server-dev-key
OTS_API_KEY_HEADER=x-api-key
OTS_PUBLIC_PATHS=/docs,/openapi.json,/favicon.ico

OTS_CELERY_BROKER_URL=sqla+postgresql+psycopg://ots:ots@postgres:5432/ots
OTS_CELERY_RESULT_BACKEND=db+postgresql+psycopg://ots:ots@postgres:5432/ots
OTS_CELERY_TASK_ALWAYS_EAGER=false
OTS_CELERY_CONCURRENCY=1
OTS_CELERY_LOGLEVEL=info

OTS_OLLAMA_HOST=http://host.docker.internal:11434
OTS_FASTEMBED_CACHE_DIR=/app/data/models/fastembed
OTS_FASTEMBED_THREADS=
OTS_FASTEMBED_PROVIDERS=

OPENAI_API_KEY=

OTS_EMBEDDING_PROVIDER=ollama
OTS_EMBEDDING_MODEL=
OTS_EMBEDDING_MODEL_KEY=
OTS_EMBEDDING_DIMENSIONS=
OTS_EMBEDDING_PARALLEL_REQUESTS=1

OTS_QUERY_EMBEDDING_CACHE_SIZE=1024
OTS_DISABLE_QUERY_EMBEDDING_CACHE=true
